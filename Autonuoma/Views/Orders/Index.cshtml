@model List<OrderViewModel>

@{
    ViewData["title"] = "Mano užsakymai";
}

<style>
.order-list{
    display:flex;
    flex-direction:column;
    gap:20px;
}

.order-card{
    border:2px solid #e0e0e0;
    border-radius:12px;
    padding:25px;
    transition:.2s;
}

.order-card:hover{
    border-color:#1bd15d;
}

.order-header{
    display:flex;
    justify-content:space-between;
    align-items:center;
}

.order-id{
    font-size:22px;
    font-weight:bold;
}

.order-price{
    color:#1bd15d;
    font-size:24px;
    font-weight:bold;
}

.order-info{
    margin-top:10px;
    color:#666;
}

.btn-open{
    margin-top:15px;
    display:inline-block;

    background:#1bd15d;
    color:white;

    padding:10px 20px;

    border-radius:30px;

    text-decoration:none;
}
</style>

<div class="cart-wrapper">

<div class="header-container">
    <div class="cart-header">Mano užsakymai</div>

    <a href="/Menu" class="btn-back">
        <i class="fa-solid fa-arrow-left"></i>
        Meniu
    </a>
</div>

@if (!Model.Any())
{
    <div class="empty-cart-msg">
        Neturite užsakymų
    </div>
}
else
{
<div class="order-list">

@foreach(var o in Model)
{
<div class="order-card">

<div class="order-header">
<div class="order-id">
Užsakymas #@o.Id
</div>

<div class="order-price">
@o.Kaina.ToString("0.00") €
</div>
</div>

<div class="order-info">

<div>
Data: @o.Data.ToString("yyyy-MM-dd")
</div>

<div>
Adresas: @o.Adresas
</div>

<div>
Statusas: @o.Statusas
</div>

</div>

<a class="btn-open"
href="/Orders/Order/@o.Id">

Peržiūrėti

</a>

</div>
}

</div>
}

</div>